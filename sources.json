{
  "feeds": [
   {
      "id": "meizhitu",
      "name": "美之图",
      "url": "https://kkmzt.com/photo/",
      "description": "影视平面图",
      "rule": "<a class=\"uk-inline u-thumb-v\" href=\"{%}\"><img width=\"640\" height=\"960\" data-src=\"{*}\" data-srcset=\"{%}\" alt=\"{%}\" uk-img=\"\" src=\"{*}\"></a>",
      "options": {
        "stripHtml": true,
        "decodeEntities": true,
        "trimContent": true
      },
      "tpl": {
        "title": "{%3}",
        "link": "{%1}",
        "content": "<img src=\"{%2}\" width=\"100%\">"
      },
      "maxItems": 50,
      "updateInterval": "6h",
      "language": "zh-CN",
      "proxy": true
    },
    {
      "id": "tiktok",
      "name": "Tiktok",
      "url": "https://919129.xyz",
      "description": "测试02",
      "rule": "<meta itemprop=\"author\" content=\"lux8pw\" /><meta itemprop=\"name\" content=\"{%}\" /><meta itemprop=\"description\" content=\"{*}\" /><meta itemprop=\"duration\" content=\"{*}\" /><meta itemprop=\"thumbnailUrl\" content=\"{%}\" /><meta itemprop=\"contentURL\" content=\"{%}\" /><meta itemprop=\"uploadDate\" content=\"{*}\" />",
      "options": {
        "stripHtml": true,
        "decodeEntities": true,
        "trimContent": true
      },
      "tpl": {
        "title": "{%1}",
        "link": "{%3}",
        "content": "<video src=\"{%3}\" class=\"relative size-full object-cover\" playsinline=\"\" poster=\"{%2}\"></video>"
      },
      "maxItems": 50,
      "updateInterval": "6h",
      "language": "zh-CN"
    },
    {
      "id": "xiannvshe",
      "name": "仙女社",
      "url": "https://n1p1.com/",
      "description": "影视平面图",
      "rule": "<div class=\"img\">\n        <a href=\"{*}\" title=\"{%} [{*}]\" target=\"_blank\" rel=\"bookmark\">\n        <img src=\"{*}\" data-src=\"{%}\" class=\"thumb\" alt=\"{*}\">\n                </a>\n    </div>",
      "options": {
        "stripHtml": true,
        "decodeEntities": true,
        "trimContent": true
      },
      "tpl": {
        "title": "{%1}",
        "link": "{%2}",
        "content": "<img src=\"{%2}\" width=\"100%\">"
      },
      "maxItems": 50,
      "updateInterval": "6h",
      "language": "zh-CN"
    }
  ]
}
