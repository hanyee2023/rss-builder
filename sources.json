{
  "feeds": [
    {
      "id": "meirishipin",
      "name": "Twstalker@每日视频",
      "url": "https://twstalker.com/kathyreid367511",
      "description": "视频分享",
      "rule": "<div class=\"activity-descp\">\n                                                        <p>{%}  </p>\n                                                        \n                                                            <div class=\"card card-raised card-carousel\">\n                                                                <div id=\"{*}\" class=\"carousel slide\" data-ride=\"carousel\" data-interval=\"999000\">\n                                                                                                                                        <div class=\"carousel-inner\">\n                                                                        <div class=\"carousel-item active\"><video rel=\"nofollow\" alt=\"Second slide\" controls=\"\" poster=\"{%}\" class=\"d-block w-100\"><source src=\"{%}\" type=\"video/mp4\"></video></div>                                                                    </div>\n                                                                                                                                    </div>\n                                                            </div>",
      "options": {
        "stripHtml": true,
        "decodeEntities": true,
        "trimContent": true
      },
      "tpl": {
        "title": "{%1}",
        "link": "{%3}",
        "content": "<video src=\"{%3}\" class=\"relative size-full object-cover\" playsinline=\"\" poster=\"{%2}\"></video>"
      },
      "maxItems": 50,
      "updateInterval": "6h",
      "proxy": true
    }
  ]
