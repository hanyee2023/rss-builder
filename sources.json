{
  "feeds": [
    {
      "id": "meirifenxiang",
      "name": "Twitter@每日分享",
      "url": "https://zamantika.com/profile/kathyreid367511",
      "description": "视频分享",
      "rule": "<div class=\"{*} tweet-text\">{%}</div>{*}<video src=\"{%}\" poster=\"{%}\" class=\"{*}\" muted=\"\" playsinline=\"\" preload=\"metadata\"></video>",
      "options": {
        "stripHtml": true,
        "decodeEntities": true,
        "trimContent": true
      },
      "tpl": {
        "title": "{%1}",
        "link": "{%2}",
        "content": "<video src=\"{%2}\" class=\"relative size-full object-cover\" playsinline=\"\" poster=\"{%3}\"></video>"
      },
      "maxItems": 50,
      "updateInterval": "6h",
      "proxy": "puppeteer"
    },
    {
      "id": "feed-1",
      "name": "山狗",
      "url": "https://media.3go.fun/latest",
      "description": "自拍视频",
      "rule": "<div class=\"item-content\"><a href=\"https://media.3go.fun/view?m={*}\" title=\"{%}\" tabindex=\"-1\" aria-hidden=\"true\" class=\"item-thumb\" style=\"background-image: url(&quot;https://media.3go.fun/media/original/thumbnails/user/91%E8%87%AA%E6%8B%8D%E8%A7%86%E9%A2%91/{%}_{%}.{%}.mp4.jpg&quot;);\">",
      "options": {
        "stripHtml": true,
        "decodeEntities": true,
        "trimContent": true
      },
      "tpl": {
        "title": "{%1}",
        "link": "https://media.3go.fun/media/original/user/91%E8%87%AA%E6%8B%8D%E8%A7%86%E9%A2%91/{%2}.{%4}.mp4",
        "content": "<video src=\"https://media.3go.fun/media/original/user/91%E8%87%AA%E6%8B%8D%E8%A7%86%E9%A2%91/{%2}.{%4}.mp4\" class=\"relative size-full object-cover\" playsinline=\"\" poster=\"https://media.3go.fun/media/original/thumbnails/user/91%E8%87%AA%E6%8B%8D%E8%A7%86%E9%A2%91/{%2}_{%3}.{%4}.mp4.jpg\"></video>"
      },
      "maxItems": 50,
      "updateInterval": "6h",
      "proxy": "puppeteer"
    },
    {
      "id": "孔雀海",
      "name": "RSS Feed",
      "url": "https://www.kq001.cc/cos",
      "description": "RSS Feed",
      "rule": "<div class=\"item-body flex xx flex1 jsb\"><h2 class=\"item-heading\"><a href=\"https://www.kq001.cc/{%}\">{%} – {*}</a></h2><a class=\"thumb-items\" href=\"https://www.kq001.cc/{*}\"><span><img src=\"{*}\" data-src=\"/wp-content/uploads/{%}-480x{*}.jpg\" class=\"{*}\" alt=\"{*}\"></span><span><img src=\"{*}\" data-src=\"/wp-content/uploads/{%}-480x{*}.jpg\" class=\"{*}\" alt=\"{*}\"></span><span><img src=\"{*}\" data-src=\"/wp-content/uploads/{%}-480x{*}.jpg\" class=\"{*}\" alt=\"{*}\"></span><span><div class=\"{*}\"><badge class=\"{*}\"><i class=\"{*}\" aria-hidden=\"true\"></i>{*}</badge></div><img src=\"{*}\" data-src=\"/wp-content/uploads/{%}-480x{*}.jpg\" class=\"{*}\" alt=\"{*}\"></span></a><div>",
