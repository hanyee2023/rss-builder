{
  "feeds": [
    {
      "id": "kongquehai",
      "name": "孔雀海",
      "url": "https://www.kqqol.com/",
      "description": "孔雀海最新更新",
      "rule": "<h2>{%}</h2>\n<a href=\"{%}\">{*}</a>\n<div class=\"content\">{%}</div>",
      "options": {
        "stripHtml": true,
        "decodeEntities": true,
        "trimContent": true
      },
      "tpl": {
        "title": "{%1}",
        "link": "{%2}",
        "content": "{%3}"
      },
      "maxItems": 50,
      "updateInterval": "daily",
      "language": "zh-CN"
    },
    {
      "id": "tiktok",
      "name": "Tiktok",
      "url": "https://919129.xyz",
      "description": "测试02",
      "rule": "<meta itemprop=\"author\" content=\"lux8pw\" /><meta itemprop=\"name\" content=\"{%}\" /><meta itemprop=\"description\" content=\"{*}\" /><meta itemprop=\"duration\" content=\"{*}\" /><meta itemprop=\"thumbnailUrl\" content=\"{%}\" /><meta itemprop=\"contentURL\" content=\"{%}\" /><meta itemprop=\"uploadDate\" content=\"{*}\" />",
      "options": {
        "stripHtml": true,
        "decodeEntities": true,
        "trimContent": true
      },
      "tpl": {
        "title": "{%1}",
        "link": "{%3}",
        "content": "<video src=\"{%3}\" class=\"relative size-full object-cover\" playsinline=\"\" poster=\"{%2}\"></video>"
      },
      "maxItems": 50,
      "updateInterval": "daily"
    },
    {
      "id": "blog-posts",
      "name": "某博客最新文章",
      "url": "https://blog.example.com",
      "description": "博客最新文章列表",
      "rule": "<div class=\"post-item\">\n  <h2><a href=\"{%}\">{%}</a></h2>\n  <div class=\"excerpt\">{%}</div>\n</div>",
      "options": {
        "stripHtml": true,
        "decodeEntities": true,
        "trimContent": true
      },
      "tpl": {
        "title": "{%2}",
        "link": "{%1}",
        "content": "{%3}"
      },
      "maxItems": 20,
      "updateInterval": "daily",
      "language": "zh-CN"
    }
  ]
}
