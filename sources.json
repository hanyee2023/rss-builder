{
  "feeds": [
    {
      "id": "meirifenxiang",
      "name": "Twitter@每日分享",
      "url": "https://zamantika.com/profile/kathyreid367511",
      "description": "视频分享",
      "rule": "<div class=\"{*} tweet-text\">{%}</div>{*}<video src=\"{%}\" poster=\"{%}\" class=\"{*}\" muted=\"\" playsinline=\"\" preload=\"metadata\"></video>",
      "options": {
        "stripHtml": true,
        "decodeEntities": true,
        "trimContent": true
      },
      "tpl": {
        "title": "{%1}",
        "link": "{%2}",
        "content": "<video src=\"{%2}\" class=\"relative size-full object-cover\" playsinline=\"\" poster=\"{%3}\"></video>"
      },
      "maxItems": 50,
      "updateInterval": "6h",
      "proxy": "puppeteer"
    },
    {
      "id": "feed-1",
      "name": "美之图",
      "url": "https://kkmzt.com/photo/",
      "description": "美女图片",
      "rule": "<a class=\"uk-inline u-thumb-v\" href=\"{%}\"><img width=\"640\" height=\"960\" data-src=\"{*}\" data-srcset=\"{%}\" alt=\"{%}\" uk-img=\"\" src=\"{*}\"></a>",
      "options": {
        "stripHtml": true,
        "decodeEntities": true,
        "trimContent": true
      },
      "tpl": {
        "title": "{%3}",
        "link": "{%1}",
        "content": "<img src=\"{%2}\" width=\"100%\">"
      },
      "maxItems": 50,
      "updateInterval": "6h",
      "proxy": "puppeteer"
    }
  ]
}